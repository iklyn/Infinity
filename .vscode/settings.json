{
  "swift.path": "/usr/bin",
  "swift.buildArguments": [],
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "[swift]": {
    "editor.defaultFormatter": "sswg.swift-lang"
  },
  "files.exclude": {
    "build/": true,
    "**/.DS_Store": true,
    "**/*.o": true,
    "**/*.d": true
  },
  "search.exclude": {
    "build/": true
  }
}
